# Daybreak Firebase configuration
#
# 1. Create a project at https://console.firebase.google.com
# 2. Add a Web app to the project (the </> icon) and copy its config values.
# 3. In the console, enable Authentication > Sign-in method > Google.
# 4. Create a Firestore database (Build > Firestore Database > Create).
# 5. Copy this file to ".env.local" and paste your real values below.
# 6. Restart "npm run dev".
#
# Leaving these blank is fine. The app then runs in local-only mode using
# localStorage, with the dummy priorities shown by default.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
