rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authed() { return request.auth != null; }
    function email() { return request.auth.token.email; }

    // Boards: only the owner, co-owners, or members can read or write.
    function boardAllowed(data) {
      return data.ownerId == email()
        || (data.owners != null && email() in data.owners)
        || (data.members != null && email() in data.members);
    }
    match /boards/{boardId} {
      allow read: if authed() && boardAllowed(resource.data);
      allow create: if authed() && request.resource.data.ownerId == email();
      allow update: if authed() && boardAllowed(resource.data)
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if authed() && resource.data.ownerId == email();
    }

    // OKRs: strictly owned by the creating user.
    match /okrs/{okrId} {
      allow read: if authed() && resource.data.ownerId == email();
      allow create: if authed() && request.resource.data.ownerId == email();
      allow update, delete: if authed() && resource.data.ownerId == email();
    }

    // Users: anyone signed in can read profiles (for assignment and names),
    // but you can only write a user document that carries your own email.
    match /users/{userId} {
      allow read: if authed();
      allow create, update: if authed() && request.resource.data.email == email();
      allow delete: if false;
    }

    // Shared lookup collections (tags, categories) for signed-in users.
    match /tags/{tagId} { allow read, write: if authed(); }
    match /categories/{categoryId} { allow read, write: if authed(); }

    // No catch-all: anything not matched above is denied by default.
  }
}
